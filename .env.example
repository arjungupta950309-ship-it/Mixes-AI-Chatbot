# Copy to .env and fill in keys. NEVER commit the real .env.

# ============ Provider selection ============
# Free stack (default): local HF embeddings + Hugging Face Inference LLM
EMBED_PROVIDER=huggingface
LLM_PROVIDER=huggingface

# ============ Hugging Face (free LLM + deployment token) ============
# Get a token at https://huggingface.co/settings/tokens (Read access is enough)
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxx
HF_CHAT_MODEL=meta-llama/Llama-3.1-8B-Instruct

# ============ Other free providers (blocked in some regions) ============
GOOGLE_API_KEY=AIxxxxxxxxxxxxxxxxxxxx
GEMINI_CHAT_MODEL=gemini-2.0-flash
GITHUB_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxx
GITHUB_CHAT_MODEL=gpt-4o-mini

# ============ Groq (alternative free LLM) ============
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx
GROQ_CHAT_MODEL=llama-3.3-70b-versatile

# ============ OpenAI (set providers above to 'openai' to use) ============
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxx
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

# ============ Local embedding model ============
HF_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
